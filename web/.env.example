# Copy this file to `.env.local` and fill in real values (never commit `.env.local`).
#
# Sign-in: Supabase Auth (email/password + Google OAuth). The RenoFlow session cookie is minted after login.
# Minimum: RENOFLOW_AUTH_SECRET, NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY.
#
# Optional legacy POST /api/auth/login (single env user) still reads RENOFLOW_USERNAME / RENOFLOW_PASSWORD when used.
#
# RENOFLOW_SUPABASE_USER_ID — optional fallback UUID for API routes if the session cookie has no uid (prefer sign-in).

RENOFLOW_AUTH_SECRET=
RENOFLOW_USERNAME=
RENOFLOW_PASSWORD=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RENOFLOW_SUPABASE_USER_ID=

# Direct Postgres URI (for npm run db:migrate:cached-products). Supabase → Settings → Database → Connection string (URI).
# DATABASE_URL=

# Google OAuth: Supabase Dashboard → Authentication → Providers → Google (Web client ID/secret).
# Redirect URLs (Authentication → URL configuration) must include both:
#   http://localhost:3000/api/auth/callback
#   http://localhost:3000/auth/callback
#   https://<your-production-domain>/api/auth/callback
#   https://<your-production-domain>/auth/callback
# Site URL in Supabase Auth settings should match your app origin.

# Supplier cache: SerpAPI is used only for (1) offline seed scripts and (2) the explicit “Check prices” action in /final.
# HOMEDEPOT_INTERNAL_KEY — long random string; required on GET /api/homedepot (seed scripts send Authorization: Bearer …).
# SERPAPI_KEY — https://serpapi.com — required for seeds and for POST /api/cached-products/refresh-from-supplier.
# HOMEDEPOT_INTERNAL_KEY=
# SERPAPI_KEY=

# Optional: send invoices by email from /final (Resend — https://resend.com )
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=RenoFlow <invoices@yourdomain.com>

# Optional: public base URL for customer invite links (defaults to request Host in dev)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Onboarding: `next dev` already sends you through /onboarding from home; set to `false` to match production.
# Set to `true` to force that behavior in production builds too.
# NEXT_PUBLIC_RESET_ONBOARDING_ON_EACH_VISIT=false
