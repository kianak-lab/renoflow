# Copy this file to `.env.local` and fill in real values (never commit `.env.local`).
#
# Sign-in uses username + password only (no email, no magic link). Defaults if unset:
#   RENOFLOW_USERNAME=renoflow
#   RENOFLOW_PASSWORD=renoflow
# Production: set RENOFLOW_USERNAME, RENOFLOW_PASSWORD, and RENOFLOW_AUTH_SECRET.
#
# Minimum for the app shell + /final:
#   RENOFLOW_AUTH_SECRET — long random string (signs the session cookie)
#
# Supabase-backed API routes (projects, clients, rooms, workspace) need:
#   NEXT_PUBLIC_SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY
#   RENOFLOW_SUPABASE_USER_ID — UUID from Supabase → Authentication → Users (row owner for RLS)

RENOFLOW_AUTH_SECRET=
RENOFLOW_USERNAME=
RENOFLOW_PASSWORD=

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RENOFLOW_SUPABASE_USER_ID=

# Direct Postgres URI (for npm run db:migrate:cached-products). Supabase → Settings → Database → Connection string (URI).
# DATABASE_URL=

# Often needed if you use the browser Supabase client anywhere
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supplier cache: SerpAPI is used only for (1) offline seed scripts and (2) the explicit “Check prices” action in /final.
# HOMEDEPOT_INTERNAL_KEY — long random string; required on GET /api/homedepot (seed scripts send Authorization: Bearer …).
# SERPAPI_KEY — https://serpapi.com — required for seeds and for POST /api/cached-products/refresh-from-supplier.
# HOMEDEPOT_INTERNAL_KEY=
# SERPAPI_KEY=

# Optional: send invoices by email from /final (Resend — https://resend.com )
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=RenoFlow <invoices@yourdomain.com>

# Optional: public base URL for customer invite links (defaults to request Host in dev)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Onboarding: `next dev` already sends you through /onboarding from home; set to `false` to match production.
# Set to `true` to force that behavior in production builds too.
# NEXT_PUBLIC_RESET_ONBOARDING_ON_EACH_VISIT=false
