# Copy this file to `.env.local` and fill in real values (never commit `.env.local`).
#
# Default (if unset): username renoflow, password renoflow. Set RENOFLOW_USERNAME, RENOFLOW_PASSWORD,
# and RENOFLOW_AUTH_SECRET in production.
#
# Minimum required:
#   RENOFLOW_AUTH_SECRET — any long random string (used to sign the app session cookie)
#   RENOFLOW_USERNAME / RENOFLOW_PASSWORD — simple login for /final (defaults: renoflow / renoflow if unset)
#   NEXT_PUBLIC_SUPABASE_URL — from Supabase → Project Settings → API
#   SUPABASE_SERVICE_ROLE_KEY — required for sign-in (server resolves auth.users id via Admin API; also used for API routes / RLS)
#     Alternative: set RENOFLOW_SUPABASE_USER_ID to a UUID from Supabase → Authentication → Users (skips Admin API).
#
# You can leave RENOFLOW_SUPABASE_USER_ID unset; it is auto-resolved on login (bootstrap Supabase auth user).
# Optional: RENOFLOW_BOOTSTRAP_EMAIL — use this email for the bootstrap user instead of the default derived from username.

RENOFLOW_AUTH_SECRET=
RENOFLOW_USERNAME=
RENOFLOW_PASSWORD=

NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: pin session to an existing auth.users id (skips auto bootstrap)
# RENOFLOW_SUPABASE_USER_ID=

# Optional: email for the auto-created Supabase user (default: <username>@renoflow.local pattern)
# RENOFLOW_BOOTSTRAP_EMAIL=you@example.com

# Often needed for browser Supabase client (if you use @supabase/ssr in the app)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: send invoices by email from /final (Resend — https://resend.com )
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=RenoFlow <invoices@yourdomain.com>

# Optional: public base URL for customer invite links (defaults to request Host in dev)
# NEXT_PUBLIC_APP_URL=https://your-domain.com
