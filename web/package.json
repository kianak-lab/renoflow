{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "cache:clean": "node ./scripts/clean-next-cache.cjs",
    "sync-final": "node ./scripts/sync-final-html.cjs",
    "og:render": "node ./scripts/render-og-image.cjs",
    "dev:clean": "node ./scripts/clean-next.cjs && next dev",
    "dev:turbopack": "next dev --turbopack",
    "build:rf-material": "node ./scripts/bundle-rf-material-search.cjs",
    "build": "node ./scripts/sync-final-html.cjs && node ./scripts/render-og-image.cjs && node ./scripts/bundle-rf-material-search.cjs && next build",
    "dev": "node ./scripts/bundle-rf-material-search.cjs && next dev",
    "start": "next start",
    "lint": "next lint",
    "seed:products": "npx tsx ./scripts/seedProducts.ts",
    "seed:products:pass2": "npx tsx ./scripts/seedProductsPass2.ts",
    "db:migrate:cached-products": "npx tsx ./scripts/apply-cached-products-migration.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "next": "15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.2",
    "pg": "^8.16.0",
    "@types/pg": "^8.11.0"
  }
}
